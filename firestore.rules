rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string
    //   - email: string
    //   - name: string
    //   - role: string (customer, admin)
    //   - createdAt: timestamp
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - name, description, category, imageUrl: string
    //   - price, stock, rating, reviewCount: number
    //   - createdAt: timestamp
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - userId: string
    //   - items: list
    //   - totalAmount: number
    //   - status: string
    //   - shippingAddress: string
    //   - paymentId: string
    //   - createdAt: timestamp
    //
    // Collection: reviews
    // Document ID: {reviewId}
    // Fields:
    //   - productId, userId, userName, comment: string
    //   - rating: number
    //   - createdAt: timestamp
    //
    // Collection: favorites
    // Document ID: {favoriteId}
    // Fields:
    //   - userId, productId: string
    //   - createdAt: timestamp
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "auradialai@gmail.com"));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function isValidUser() {
      let data = request.resource.data;
      return hasRequiredFields(['uid', 'email', 'name', 'role', 'createdAt']) &&
        data.uid is string && data.uid.size() > 0 &&
        data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
        data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
        data.role in ['customer', 'admin'] &&
        data.createdAt is timestamp;
    }

    function isValidProduct() {
      let data = request.resource.data;
      return hasRequiredFields(['name', 'price', 'category', 'stock', 'createdAt']) &&
        data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
        data.price is number && data.price >= 0 &&
        data.category is string && data.category.size() < 50 &&
        data.stock is number && data.stock >= 0 &&
        (!('description' in data) || (data.description is string && data.description.size() < 5000)) &&
        (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 500)) &&
        (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
        (!('reviewCount' in data) || (data.reviewCount is number && data.reviewCount >= 0)) &&
        data.createdAt is timestamp;
    }

    function isValidOrder() {
      let data = request.resource.data;
      return hasRequiredFields(['userId', 'items', 'totalAmount', 'status', 'shippingAddress', 'createdAt']) &&
        data.userId is string && data.userId == request.auth.uid &&
        data.items is list && data.items.size() > 0 && data.items.size() < 100 &&
        data.totalAmount is number && data.totalAmount >= 0 &&
        data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
        data.shippingAddress is string && data.shippingAddress.size() < 300 &&
        (!('paymentId' in data) || (data.paymentId is string && data.paymentId.size() < 100)) &&
        data.createdAt is timestamp;
    }

    function isValidReview() {
      let data = request.resource.data;
      return hasRequiredFields(['productId', 'userId', 'userName', 'rating', 'comment', 'createdAt']) &&
        data.productId is string && data.productId.size() > 0 && data.productId.size() < 50 &&
        data.userId is string && data.userId == request.auth.uid &&
        data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
        data.rating is number && data.rating >= 1 && data.rating <= 5 &&
        data.comment is string && data.comment.size() < 1000 &&
        data.createdAt is timestamp;
    }

    function isValidFavorite() {
      let data = request.resource.data;
      return hasRequiredFields(['userId', 'productId', 'createdAt']) &&
        data.userId is string && data.userId == request.auth.uid &&
        data.productId is string && data.productId.size() > 0 && data.productId.size() < 50 &&
        data.createdAt is timestamp;
    }


    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser() && 
        uidUnchanged() && 
        ((data.role == 'customer') || isAdmin());
      allow update: if isAuthenticated() && isValidUser() && 
        uidUnchanged() && areImmutableFieldsUnchanged(['uid', 'email', 'createdAt']) &&
        ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidProduct();
      allow update: if isAdmin() && isValidProduct() && areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidOrder();
      allow update: if isAdmin() && isValidOrder() && areImmutableFieldsUnchanged(['userId', 'items', 'totalAmount', 'createdAt']);
    }

    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidReview();
      allow update: if isAuthenticated() && isValidReview() && isDocOwner() && areImmutableFieldsUnchanged(['productId', 'userId', 'createdAt']);
      allow delete: if isAdmin() || isDocOwner();
    }

    match /favorites/{favoriteId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidFavorite();
      allow delete: if isDocOwner();
    }
  }
}
